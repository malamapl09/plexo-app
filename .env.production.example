# ================================
# Plexo Operations - Production Environment
# Copy to .env and fill in all values
# ================================

# Application
APP_NAME=Plexo
NEXT_PUBLIC_APP_NAME=Plexo
NEXT_PUBLIC_APP_LOGO=/logo.png
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Database (RDS)
POSTGRES_USER=plexo
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=plexo
RDS_HOST=your-rds-instance.xxxxxx.us-east-1.rds.amazonaws.com

# Redis (ElastiCache)
REDIS_HOST=your-elasticache-endpoint.xxxxxx.0001.use1.cache.amazonaws.com
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Storage (S3)
STORAGE_MODE=s3
AWS_S3_BUCKET=plexo-uploads
AWS_S3_REGION=us-east-1

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Firebase (optional - for push notifications)
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# Email (Amazon SES)
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_SES_REGION=us-east-1

# Application URL (for email links)
APP_URL=https://app.yourdomain.com

# Monitoring — Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Monitoring — Better Stack (uptime, logs, heartbeats)
# Get these from https://betterstack.com → Telemetry → Sources → Node.js
BETTERSTACK_LOGS_TOKEN=your-logtail-source-token
# Create heartbeats at https://betterstack.com → Uptime → Heartbeats
BETTERSTACK_HEARTBEAT_WEEKLY_RESET=https://uptime.betterstack.com/api/v1/heartbeat/xxxx
BETTERSTACK_HEARTBEAT_MONTHLY_RESET=https://uptime.betterstack.com/api/v1/heartbeat/xxxx
BETTERSTACK_HEARTBEAT_DAILY_COMPLIANCE=https://uptime.betterstack.com/api/v1/heartbeat/xxxx
BETTERSTACK_HEARTBEAT_DAILY_SYNC=https://uptime.betterstack.com/api/v1/heartbeat/xxxx
